# Supabase — get these from Project Settings → API in supabase.com
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-jwt
SUPABASE_SERVICE_ROLE_KEY=your-service-role-jwt

# Shared secret used by /api/revalidate — pick a long random string.
REVALIDATE_SECRET=change-me-to-a-long-random-string
